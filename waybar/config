{
  "layer": "top",
  "position": "top",
  "modules-left": ["sway/workspaces"],
  "modules-center": [
  "custom/bandwidth"
  ],
  "modules-right": [
    "custom/vpn",
    "network#vpn",
    "network#wifi",
    "cpu",
    "memory",
    "pulseaudio",
    "clock",
    "tray"
  ],

  "custom/vpn": {
    "exec": "~/.config/waybar/scripts/netstatus.sh",
    "exec-if": "test -x ~/.config/waybar/scripts/netstatus.sh",
    "interval": 10,
    "return-type": "text",
    "format": "{}",
    "tooltip": false
  },

  "custom/bandwidth": {
    "exec": "~/.config/waybar/scripts/bandwidth.sh",
    "exec-if": "test -x ~/.config/waybar/scripts/bandwidth.sh",
    "interval": 2,
    "return-type": "text",
    "format": "{}"
  },

  "clock": {
    "format": "{:%a %d %b  %H:%M:%S}",
    "tooltip-format": "{:%Y-%m-%d %H:%M:%S}",
    "interval": 1
  },

  "pulseaudio": {
    "scroll-step": 5,
    "format": " {volume}%",
    "format-muted": " Muted",
    "format-source": " {volume}%",
    "format-source-muted": " Muted Mic",
    "on-click": "pavucontrol",
    "sources": true,
    "sinks": true
  },
 
  "network#vpn": {
    "interface": "proton0",
    "format": "VPN: {ipaddr}",
    "format-disconnected": "VPN: Disconnected",
    "tooltip-format": "{ifname} - {ipaddr}",
    "on-click": "nm-connection-editor"
  },
  "network#eth": {
    "interface": "enp12s0",
    "format": "Eth: {ifname}",
    "format-disconnected": "{ifname}: Down",
    "tooltip-format": "{ifname} - {ipaddr} via {gwaddr}\n",
    "on-click": "nm-connection-editor",
  },
  "network#wifi": {
    "interface": "wlp11s0",
    "format": "WiFi: {ifname}",
    "format-disconnected": "{ifname}: Down",
    "tooltip-format": "{ifname} - {ipaddr} via {gwaddr}\n",
    "on-click": "nm-connection-editor",
  },

  "cpu": {
    "format": " {usage}%",
    "tooltip": true
  },

  "memory": {
    "format": " {used:0.1f}G",
    "tooltip": true
  },

  "temperature": {
    "critical-threshold": 75,
    "format": " {temperatureC}°C",
    "tooltip": false
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8
  }
}

