{
  "layer": "top",
  "position": "top",
  "modules-left": ["sway/workspaces", "sway/window"],
  "modules-center": [
  "custom/bandwidth"
  ],
  "modules-right": [
    "network#vpn",
    "network#wifi",
    "custom/gpu",
    "cpu",
    "memory",
    "disk",
    "pulseaudio",
    "clock",
    "tray"
  ],

  "sway/window": {
    "max-length": 60,
    "format": "{}",
    "tooltip": false
  },

  "custom/bandwidth": {
    "exec": "~/.config/waybar/scripts/bandwidth.sh",
    "exec-if": "test -x ~/.config/waybar/scripts/bandwidth.sh",
    "interval": 2,
    "return-type": "text",
    "format": "{}"
  },

  "custom/gpu": {
    "exec": "~/.config/waybar/scripts/gpu.sh",
    "exec-if": "test -x ~/.config/waybar/scripts/gpu.sh",
    "interval": 5,
    "return-type": "text",
    "format": "{}"
  },

  "clock": {
    "format": "\uf017 {:%a %d %b  %H:%M:%S}",
    "tooltip-format": "{:%Y-%m-%d %H:%M:%S}",
    "interval": 1
  },

  "pulseaudio": {
    "scroll-step": 5,
    "format": "\uf028 {volume}%",
    "format-muted": " Muted",
    "format-source": "\uf130 {volume}%",
    "format-source-muted": " Muted Mic",
    "on-click": "pavucontrol",
    "sources": true,
    "sinks": true
  },

  "network#vpn": {
    "interface": "proton0",
    "format": "\uf132 VPN: {ipaddr}",
    "format-disconnected": "\uf132 VPN: Off",
    "tooltip-format": "{ifname} - {ipaddr}",
    "on-click": "nm-connection-editor"
  },

  "network#wifi": {
    "format": "\uf1eb {essid} {signaldBm}dBm",
    "format-disconnected": " Down",
    "tooltip-format": "{ifname} — {ipaddr} via {gwaddr}",
    "on-click": "nm-connection-editor"
  },

  "cpu": {
    "format": "\uf2db {usage}%",
    "tooltip": true
  },

  "memory": {
    "format": "\uf538 {used:0.1f}G",
    "tooltip": true
  },

  "disk": {
    "path": "/",
    "format": "\uf0a0 {percentage_used}%",
    "tooltip-format": "{used} / {total} used ({percentage_used}%)",
    "interval": 30
  },

  "tray": {
    "icon-size": 16,
    "spacing": 8
  }
}
